{
  "name": "@trading/worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Price polling + daily pipeline runner (spec §2 dedicated Worker)",
  "scripts": {
    "start": "node --env-file-if-exists=../../.env.local --experimental-transform-types src/index.ts",
    "pipeline:dry": "node --env-file-if-exists=../../.env.local --experimental-transform-types src/dry-run.ts",
    "news:check": "node --env-file-if-exists=../../.env.local --experimental-transform-types src/news-check.ts",
    "scrape": "node --env-file-if-exists=../../.env.local --experimental-transform-types src/run-scrape.ts",
    "digest": "node --env-file-if-exists=../../.env.local --experimental-transform-types src/run-digest.ts",
    "poll": "node --env-file-if-exists=../../.env.local --experimental-transform-types src/poll-once.ts",
    "autotrade": "node --env-file-if-exists=../../.env.local --experimental-transform-types src/auto-once.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@trading/core": "*"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "typescript": "^5.7.2"
  }
}
