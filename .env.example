# ─────────────────────────────────────────────────────────────
# Trading System — environment variables
# Copy to .env.local and fill in as keys arrive.
# DATA_MODE controls the stub/live switch:
#   mock  → all external deps return deterministic seed data (no keys needed)
#   live  → real API calls; each datasource goes live only if its key is set
# ─────────────────────────────────────────────────────────────
DATA_MODE=mock

# Market data, technicals, FX, TASE, crypto (spec §3.2)
TWELVEDATA_API_KEY=

# Deep fundamentals for US stocks (spec §3.3)
FMP_API_KEY=

# Company news + sentiment for US stocks (spec §3.4)
FINNHUB_API_KEY=

# YouTube Data API v3 — channel/video discovery (spec §3.5)
YOUTUBE_API_KEY=

# Apify — Instagram/TikTok scraping + Whisper transcription (spec §3.6)
APIFY_TOKEN=

# Claude (Anthropic) — analysis & synthesis engine (spec §3.8)
ANTHROPIC_API_KEY=

# Resend — daily digest email (spec §3.9)
RESEND_API_KEY=

# Supabase (Postgres) — provisioned later (spec §3.1 / §10)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
